#include <stdio.h>
#include <stdlib.h>
#include <math.h>

double gauss_determinant(double** matrix, int n) {
    double det = 1.0;
    for (int i = 0; i < n; i++) {
        int max_row = i;
        for (int j = i + 1; j < n; j++) {
            if (fabs(matrix[j][i]) > fabs(matrix[max_row][i])) {
                max_row = j;
            }
        }
        if (fabs(matrix[max_row][i]) < 1e-12) {
            return 0.0;
        }
        if (max_row != i) {
            double* temp = matrix[i];
            matrix[i] = matrix[max_row];
            matrix[max_row] = temp;
            det = -det;
        }
        det = det * matrix[i][i];
        for (int j = i + 1; j < n; j++) {
            if (matrix[j][i] != 0.0) {
                double factor = matrix[j][i] / matrix[i][i];
                for (int k = i; k < n; k++) {
                    matrix[j][k] = matrix[j][k] - factor * matrix[i][k];
                }
            }
        }
    }
    return det;
}

int main() {
    int n;
    scanf("%d", &n);
    double** matrix = (double**) malloc(n * sizeof(double*));
    for (int i = 0; i < n; i++) {
        matrix[i] = (double*) malloc(n * sizeof(double));
    }
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%lf", &matrix[i][j]);
        }
    }
    double determinant = gauss_determinant(matrix, n);
    printf("%lf", determinant);
    for (int i = 0; i < n; i++) {
        free(matrix[i]);
    }
    free(matrix);
    return 0;
}

